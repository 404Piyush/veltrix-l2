# Veltrix L2 OP Stack Configuration Template

# --- L1 Configuration ---
L1_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
L1_BEACON_URL=https://ethereum-sepolia-beacon-api.publicnode.com
L1_RUNTIME_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
L1_CHAIN_ID=11155111
DEPLOYER_PRIVATE_KEY=0x...

# --- L2 Configuration ---
L2_CHAIN_ID=845320
L2_BLOCK_TIME=2
SEQUENCER_PRIVATE_KEY=0x...
BATCHER_PRIVATE_KEY=0x...
PROPOSER_PRIVATE_KEY=0x...

# --- op-geth (Execution Engine) ---
OP_GETH_HTTP_ADDR=0.0.0.0
OP_GETH_HTTP_PORT=8545
OP_GETH_WS_ADDR=0.0.0.0
OP_GETH_WS_PORT=8546
OP_GETH_AUTHRPC_ADDR=0.0.0.0
OP_GETH_AUTHRPC_PORT=8551
OP_GETH_AUTHRPC_JWTSECRET=/path/to/jwt.txt

# --- op-node (Consensus Layer) ---
OP_NODE_L1_RPC_KIND=alchemy
OP_NODE_L2_ENGINE_RPC=http://op-geth:8551
OP_NODE_L2_ENGINE_AUTH=/path/to/jwt.txt
OP_NODE_P2P_PRIV_PATH=/path/to/p2p-node-key.txt
OP_NODE_L1_BEACON=https://ethereum-sepolia-beacon-api.publicnode.com

# --- op-batcher ---
OP_BATCHER_L1_ETH_RPC=http://l1-rpc
OP_BATCHER_L2_ETH_RPC=http://op-geth:8545
OP_BATCHER_ROLLUP_RPC=http://op-node:9545
OP_BATCHER_POLL_INTERVAL=1s
OP_BATCHER_SUB_SAFETY_MARGIN=4
OP_BATCHER_NUM_CONFIRMATIONS=1

# --- op-proposer ---
OP_PROPOSER_L1_ETH_RPC=http://l1-rpc
OP_PROPOSER_ROLLUP_RPC=http://op-node:9545
OP_PROPOSER_POLL_INTERVAL=12s
OP_PROPOSER_L2_OUTPUT_ORACLE=0x...
